# Database
DATABASE_URL="mysql://root:@127.0.0.1:3306/aa_travel_group"

# JWT
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Nodemailer (SMTP)
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT=587
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
MAIL_FROM="AA Travel Group <no-reply@aatravelgroup.co.uk>"
ADMIN_NOTIFY_EMAIL="enquiries@aatravelgroup.co.uk"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-key"

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER="447000000000"

# Site
NEXT_PUBLIC_SITE_URL="https://www.aatravelgroup.co.uk"
