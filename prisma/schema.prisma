generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum HotelStar {
  THREE
  FOUR
  FIVE
  LUXURY_SUITE
}

enum HotelCity {
  MAKKAH
  MADINAH
}

enum EnquiryStatus {
  NEW
  CONTACTED
  QUOTED
  CONFIRMED
  CLOSED
}

enum AgentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Admin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  blogPosts    BlogPost[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  country      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  bookings     Booking[]
}

model Hotel {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  city           String
  star           HotelStar
  description    String       @db.Text
  distanceMeters Int
  address        String
  latitude       Float?
  longitude      Float?
  featured       Boolean      @default(false)
  active         Boolean      @default(true)
  metaTitle      String?
  metaDescription String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  images         HotelImage[]
  amenities      HotelAmenity[]
  rooms          Room[]
  reviews        Review[]
  bookings       Booking[]

  @@index([city, star])
}

model HotelImage {
  id       String @id @default(cuid())
  hotelId  String
  hotel    Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  url      String
  publicId String
  altText  String?
  position Int    @default(0)

  @@index([hotelId])
}

model Amenity {
  id     String         @id @default(cuid())
  name   String         @unique
  icon   String?
  hotels HotelAmenity[]
}

model HotelAmenity {
  hotelId   String
  amenityId String
  hotel     Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([hotelId, amenityId])
}

model Room {
  id          String   @id @default(cuid())
  hotelId     String
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  capacity    Int
  bedType     String?
  sizeSqm     Int?
  active      Boolean  @default(true)
  bookings    Booking[]

  @@index([hotelId])
}

model Review {
  id        String   @id @default(cuid())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  authorName String
  rating    Int
  comment   String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([hotelId])
}

model Booking {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  hotelId   String
  hotel     Hotel         @relation(fields: [hotelId], references: [id])
  roomId    String?
  room      Room?         @relation(fields: [roomId], references: [id])
  checkIn   DateTime
  checkOut  DateTime
  adults    Int           @default(1)
  children  Int           @default(0)
  status    BookingStatus @default(PENDING)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([hotelId])
}

model Enquiry {
  id           String        @id @default(cuid())
  fullName     String
  country      String
  agencyName   String?
  whatsapp     String
  email        String
  checkIn      DateTime?
  checkOut     DateTime?
  destination  HotelCity?
  hotelCategory HotelStar?
  budget       String?
  adults       Int           @default(1)
  children     Int           @default(0)
  rooms        Int           @default(1)
  message      String?       @db.Text
  status       EnquiryStatus @default(NEW)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
}

model TravelAgent {
  id           String      @id @default(cuid())
  agencyName   String
  contactName  String
  email        String      @unique
  phone        String
  country      String
  website      String?
  yearsTrading Int?
  message      String?     @db.Text
  status       AgentStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Package {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  summary        String
  description    String   @db.Text
  nights         Int
  city           String
  priceFrom      Decimal? @db.Decimal(10, 2)
  inclusions     String   @db.Text
  exclusions     String?  @db.Text
  imageUrl       String?
  active         Boolean  @default(true)
  metaTitle      String?
  metaDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Testimonial {
  id         String   @id @default(cuid())
  authorName String
  authorType String // "Travel Agent" | "Family" | "Pilgrim"
  country    String?
  rating     Int      @default(5)
  quote      String   @db.Text
  avatarUrl  String?
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Category {
  id    String     @id @default(cuid())
  name  String     @unique
  slug  String     @unique
  posts BlogPost[]
}

model BlogPost {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String
  content         String   @db.Text
  coverImageUrl   String?
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  authorId        String
  author          Admin    @relation(fields: [authorId], references: [id])
  published       Boolean  @default(false)
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([categoryId])
}

model GalleryImage {
  id       String @id @default(cuid())
  url      String
  publicId String
  altText  String?
  category String // "Hotels" | "Makkah" | "Madinah" | "Transportation" | "Groups"
  position Int    @default(0)
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  createdAt DateTime @default(now())
}
